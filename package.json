  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "env-paths": "^3.0.0",
    "frida": "^17.4.4",
    "hono": "^4.10.4",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29"
  },
  "engines": {
    "node": ">=23.10.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChiChou/Grapefruit.git"
  },
  "bugs": {
